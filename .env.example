# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=studenthub
POSTGRES_USER=studenthub_user
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Caddy ─────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── Frontend (used at Docker build time) ──────────────────────────────────────
VITE_API_BASE_URL=https://yourdomain.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Paymob ────────────────────────────────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Google ────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=

# ── Google GenAI / Vertex AI (chatbot) ───────────────────────────────────────
# Option A — Vertex AI (recommended on GCP, uses VM service account automatically)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Option B — Direct Gemini API key (simpler, works anywhere)
# GEMINI_API_KEY=

# ── Persona (KYC) ─────────────────────────────────────────────────────────────
PERSONA_API_KEY=
PERSONA_INQUIRY_TEMPLATE_ID=
PERSONA_WEBHOOK_SECRET=
