{
	"info": {
		"name": "StudentHub — Services API (Google Maps)",
		"description": "Full test collection for nearby places, university distance, and geocoding.\n\n**Setup:**\n1. Set `base_url` (default: http://127.0.0.1:8000)\n2. Run request 0 — token saves automatically\n3. Set `property_id` variable to a real property ID from your DB",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url",    "value": "http://127.0.0.1:8000", "type": "string" },
		{ "key": "token",       "value": "",                       "type": "string" },
		{ "key": "property_id", "value": "1",                      "type": "string" }
	],
	"item": [
		{
			"name": "0. Auth — Get Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const res = pm.response.json();",
							"if (res.access) {",
							"    pm.collectionVariables.set(\"token\", res.access);",
							"    console.log(\"Token saved automatically.\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{ "key": "Content-Type", "value": "application/json" }],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"your_username\",\n    \"password\": \"your_password\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/login/",
					"host": ["{{base_url}}"],
					"path": ["api", "auth", "login", ""]
				}
			}
		},
		{
			"name": "── NEARBY PLACES ─────────────────",
			"item": [
				{
					"name": "1. Universities List (Public)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/services/universities/",
							"host": ["{{base_url}}"],
							"path": ["api", "services", "universities", ""]
						},
						"description": "No auth required. Returns all ~35 university names for dropdowns."
					}
				},
				{
					"name": "2. Nearby — Pharmacy (GPS)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{base_url}}/api/services/nearby/?lat=30.026&lng=31.213&type=pharmacy&radius=1500",
							"host": ["{{base_url}}"],
							"path": ["api", "services", "nearby", ""],
							"query": [
								{ "key": "lat",    "value": "30.026" },
								{ "key": "lng",    "value": "31.213" },
								{ "key": "type",   "value": "pharmacy" },
								{ "key": "radius", "value": "1500" }
							]
						},
						"description": "Google Places result. First call hits API and caches for 24h.\nNow includes rating and open_now from Google."
					}
				},
				{
					"name": "3. Nearby — Supermarket (GPS)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{base_url}}/api/services/nearby/?lat=30.026&lng=31.213&type=supermarket&radius=1500",
							"host": ["{{base_url}}"],
							"path": ["api", "services", "nearby", ""],
							"query": [
								{ "key": "lat",    "value": "30.026" },
								{ "key": "lng",    "value": "31.213" },
								{ "key": "type",   "value": "supermarket" },
								{ "key": "radius", "value": "1500" }
							]
						}
					}
				},
