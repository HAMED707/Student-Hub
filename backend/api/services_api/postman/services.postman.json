		{
			"name": "── DISTANCE MATRIX ───────────────",
			"item": [
				{
					"name": "13. Distance — Property to University (Walking)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{base_url}}/api/services/distance/?property_id={{property_id}}&mode=walking",
							"host": ["{{base_url}}"],
							"path": ["api", "services", "distance", ""],
							"query": [
								{ "key": "property_id", "value": "{{property_id}}" },
								{ "key": "mode",        "value": "walking" }
							]
						},
						"description": "Returns real walking distance + time from property to its nearby_university.\nSet the `property_id` collection variable to a real ID from your DB."
					}
				},
				{
					"name": "14. Distance — Property to University (Transit)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{base_url}}/api/services/distance/?property_id={{property_id}}&mode=transit",
							"host": ["{{base_url}}"],
							"path": ["api", "services", "distance", ""],
							"query": [
								{ "key": "property_id", "value": "{{property_id}}" },
								{ "key": "mode",        "value": "transit" }
							]
						}
					}
				},
				{
					"name": "15. Distance — Property to University (Driving)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{base_url}}/api/services/distance/?property_id={{property_id}}&mode=driving",
							"host": ["{{base_url}}"],
							"path": ["api", "services", "distance", ""],
							"query": [
								{ "key": "property_id", "value": "{{property_id}}" },
								{ "key": "mode",        "value": "driving" }
							]
						}
					}
				}
			]
		},
		{
			"name": "── GEOCODING (via property create) ──",
			"item": [
				{
					"name": "16. Create Property — Geocoding fires automatically",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type",  "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Test Property Geocoding\",\n    \"property_type\": \"apartment\",\n    \"price\": 3000,\n    \"city\": \"Cairo\",\n    \"address\": \"15 Tahrir Square, Cairo, Egypt\",\n    \"nearby_university\": \"Cairo University\",\n    \"transport_type\": \"walk\",\n    \"num_rooms\": 2,\n    \"num_beds\": 2,\n    \"num_bathrooms\": 1,\n    \"gender_preference\": \"male\",\n    \"status\": \"available\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/properties/create/",
							"host": ["{{base_url}}"],
							"path": ["api", "properties", "create", ""]
						},
						"description": "Create a property with an address but NO lat/lng.\nThe geocoding signal fires automatically and fills latitude/longitude.\nCheck the response — latitude and longitude should be populated."
					}
				},
				{
					"name": "17. Property Detail — Distance injected in response",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{base_url}}/api/properties/{{property_id}}/",
							"host": ["{{base_url}}"],
							"path": ["api", "properties", "{{property_id}}", ""]
						},
						"description": "Property detail response now includes `university_distance` field:\n{\n  \"university_distance\": {\n    \"distance_text\": \"1.2 km\",\n    \"distance_value\": 1200,\n    \"duration_text\": \"15 mins\",\n    \"duration_value\": 900,\n    \"mode\": \"walking\"\n  }\n}\nIf property has no lat/lng or no nearby_university, university_distance will be null."
					}
				}
			]
		},
