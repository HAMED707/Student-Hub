	"item": [
		{
			"name": "🛠️ SETUP - Login as Student",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    pm.environment.set(\"student_token\", jsonData.access);",
							"    console.log(\"Student token saved:\", jsonData.access.substring(0, 20) + \"...\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"student_user\",\n    \"password\": \"Testuser123\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/login/",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"login",
						""
					]
				}
			},
			"response": []
		},
		{
			"name": "🛠️ SETUP - Login as Landlord",
