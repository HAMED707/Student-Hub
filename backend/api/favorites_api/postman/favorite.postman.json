		{
			"name": "🛠️ SETUP - Get Available Property ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    var jsonData = pm.response.json();",
							"    if (jsonData.length > 0) {",
							"        pm.environment.set(\"property_id\", jsonData[0].id);",
							"        console.log(\"Using property ID:\", jsonData[0].id);",
							"    }",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/properties/?status=available",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"properties",
						""
					],
					"query": [
						{
							"key": "status",
							"value": "available"
						}
					]
				}
			},
			"response": []
		},
