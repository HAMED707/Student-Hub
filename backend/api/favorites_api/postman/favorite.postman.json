{
	"info": {
		"_postman_id": "studenthub-favorites-testing",
		"name": "StudentHub - Favorites App Testing",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000",
			"type": "default"
		},
		{
			"key": "student_token",
			"value": "",
			"type": "default"
		},
		{
			"key": "landlord_token",
			"value": "",
			"type": "default"
		},
		{
			"key": "property_id",
			"value": "",
			"type": "default"
		},
		{
			"key": "favorite_id",
			"value": "",
			"type": "default"
		}
