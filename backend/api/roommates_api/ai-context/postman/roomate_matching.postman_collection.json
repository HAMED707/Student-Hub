    {
      "name": "3 — AI Matching",
      "description": "All tests run as student 1 (Nour). Expected order: Layla (95%) > Mariam (70%) > Sara (50%) > Dina (30%). Omar must never appear.",
      "item": [
        {
          "name": "Get matches ✅ happy path",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('status is success', () => pm.expect(json.status).to.eql('success'));",
                  "pm.test('matches is array', () => pm.expect(json.matches).to.be.an('array'));",
                  "pm.test('returns at most 5', () => pm.expect(json.matches.length).to.be.at.most(5));",
                  "pm.test('returns at least 1', () => pm.expect(json.matches.length).to.be.at.least(1));",
                  "pm.test('each match has username', () => json.matches.forEach(m => pm.expect(m).to.have.property('username')));",
                  "pm.test('each match has score', () => json.matches.forEach(m => pm.expect(m).to.have.property('compatibility_score')));",
                  "pm.test('scores are 0-100', () => json.matches.forEach(m => pm.expect(m.compatibility_score).to.be.within(0, 100)));",
                  "pm.test('sorted best first', () => {",
                  "  for (let i = 0; i < json.matches.length - 1; i++) {",
                  "    pm.expect(json.matches[i].compatibility_score).to.be.at.least(json.matches[i+1].compatibility_score);",
                  "  }",
                  "});",
                  "pm.test('Omar (male) is NOT in results', () => {",
                  "  const names = json.matches.map(m => m.username);",
                  "  pm.expect(names).to.not.include('test_student6');",
                  "});",
                  "pm.test('student1 not in own results', () => {",
                  "  const names = json.matches.map(m => m.username);",
                  "  pm.expect(names).to.not.include('test_student1');",
                  "});",
                  "console.log('Match results:', JSON.stringify(json.matches, null, 2));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_s1}}" }],
            "url": "{{base_url}}/api/roommates/matches/"
          }
        },
        {
          "name": "Get matches ❌ no token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/roommates/matches/"
          }
        },
        {
          "name": "Get matches ❌ inactive profile (deactivate first)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('base_url') + '/api/roommates/profile/',",
                  "  method: 'PATCH',",
                  "  header: {",
                  "    'Authorization': 'Bearer ' + pm.collectionVariables.get('token_s1'),",
                  "    'Content-Type': 'application/json'",
                  "  },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ is_active: false }) }",
                  "}, (err, res) => {",
                  "  console.log('Profile deactivated:', res.code);",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Error mentions active profile', () => {",
                  "  pm.expect(pm.response.json().error).to.include('active roommate profile');",
                  "});",
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('base_url') + '/api/roommates/profile/',",
                  "  method: 'PATCH',",
                  "  header: {",
                  "    'Authorization': 'Bearer ' + pm.collectionVariables.get('token_s1'),",
                  "    'Content-Type': 'application/json'",
                  "  },",
                  "  body: { mode: 'raw', raw: JSON.stringify({ is_active: true }) }",
                  "}, (err, res) => {",
                  "  console.log('Profile re-activated:', res.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_s1}}" }],
            "url": "{{base_url}}/api/roommates/matches/"
          }
        }
      ]
    },
    {
      "name": "4 — Roommate Requests",
      "description": "Student 1 sends a request to student 2. Student 2 accepts/rejects/withdraws.",
      "item": [
        {
          "name": "Browse all active profiles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Student 1 not in own list', () => {",
                  "  const usernames = pm.response.json().map(p => p.user?.username);",
                  "  pm.expect(usernames).to.not.include('test_student1');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_s1}}" }],
            "url": {
              "raw": "{{base_url}}/api/roommates/?university=Cairo University&city=Cairo",
              "host": ["{{base_url}}"],
              "path": ["api", "roommates", ""],
              "query": [
                { "key": "university", "value": "Cairo University" },
                { "key": "city",       "value": "Cairo" }
              ]
            }
          }
        },
        {
          "name": "Send request (student 1 → student 2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Status is pending', () => pm.expect(json.status).to.eql('pending'));",
                  "if (json.id) pm.collectionVariables.set('request_id', String(json.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_s1}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/roommates/request/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver\": \"{{user_id_s2}}\",\n  \"message\": \"Hey Layla! We seem like a great match. Want to be roommates?\"\n}"
            }
          }
        },
        {
          "name": "View sent & received requests (student 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has sent', () => pm.expect(json).to.have.property('sent'));",
                  "pm.test('Has received', () => pm.expect(json).to.have.property('received'));",
                  "pm.test('Sent list not empty', () => pm.expect(json.sent.length).to.be.at.least(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_s1}}" }],
            "url": "{{base_url}}/api/roommates/requests/"
          }
        },
        {
          "name": "Accept request (student 2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is accepted', () => pm.expect(pm.response.json().status).to.eql('accepted'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_s2}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/roommates/request/{{request_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            }
          }
        },
        {
          "name": "Reject request (student 2) — run instead of Accept",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_s2}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/roommates/request/{{request_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}"
            }
          }
        },
        {
          "name": "Withdraw request (student 1) — run instead of Accept",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_s1}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/roommates/request/{{request_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"withdrawn\"\n}"
            }
          }
        },
        {
          "name": "❌ Receiver tries to withdraw (should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 or 403', () => pm.expect([400, 403]).to.include(pm.response.code));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_s2}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/roommates/request/{{request_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"withdrawn\"\n}"
            }
          }
        }
      ]
    }
  ]
