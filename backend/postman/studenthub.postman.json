{
  "info": {
    "name": "StudentHub API",
    "_postman_id": "studenthub-api-collection",
    "description": "Full API collection for StudentHub — accounts, properties, bookings, payments, messaging, notifications, reviews, favorites, community, and services.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ahmed_student\",\n  \"email\": \"ahmed@example.com\",\n  \"first_name\": \"Ahmed\",\n  \"last_name\": \"Hassan\",\n  \"password\": \"strongpass123\",\n  \"phone_number\": \"+201001234567\",\n  \"gender\": \"M\",\n  \"date_of_birth\": \"2000-05-15\",\n  \"role\": \"student\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access) pm.collectionVariables.set('access_token', res.access);",
                  "if (res.refresh) pm.collectionVariables.set('refresh_token', res.refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register (Landlord)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"landlord_ali\",\n  \"email\": \"ali@example.com\",\n  \"first_name\": \"Ali\",\n  \"last_name\": \"Mohamed\",\n  \"password\": \"strongpass123\",\n  \"phone_number\": \"+201009876543\",\n  \"gender\": \"M\",\n  \"date_of_birth\": \"1985-03-20\",\n  \"role\": \"landlord\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ahmed_student\",\n  \"password\": \"strongpass123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access) pm.collectionVariables.set('access_token', res.access);",
                  "if (res.refresh) pm.collectionVariables.set('refresh_token', res.refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/token/refresh/", "host": ["{{base_url}}"], "path": ["auth", "token", "refresh", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access) pm.collectionVariables.set('access_token', res.access);"
                ]
              }
            }
          ]
        }
      ]
    },

